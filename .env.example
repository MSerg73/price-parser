# Основной ключ LLM. Не добавляйте реальное значение в Git или delivery ZIP.
OPENAI_API_KEY=

# Модель для явного live-пилота.
LLM_MODEL=gpt-5.4-mini

# Legacy-совместимость. Обычно оставляется пустой.
# Если OPENAI_API_KEY и LLM_API_KEY заданы одновременно и различаются,
# программа должна остановиться.
LLM_API_KEY=

# Backend/full-project variables are optional for the test assignment.
DATABASE_URL=
AMO_CLIENT_ID=
AMO_CLIENT_SECRET=
AMO_REDIRECT_URI=
MAIL_USERNAME=
MAIL_PASSWORD=
STORAGE_TOKEN=
