{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "EquivalenceDefinition",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "source_grade_id",
    "target_grade_id",
    "relation_type",
    "status",
    "source_reference"
  ],
  "properties": {
    "id": {
      "type": "string",
      "minLength": 1
    },
    "source_grade_id": {
      "type": "string",
      "minLength": 1
    },
    "target_grade_id": {
      "type": "string",
      "minLength": 1
    },
    "relation_type": {
      "enum": [
        "EQUIVALENT",
        "APPROXIMATE"
      ]
    },
    "status": {
      "enum": [
        "CONFIRMED",
        "PROPOSED",
        "REJECTED"
      ]
    },
    "source_reference": {
      "type": "string"
    },
    "bidirectional": {
      "type": "boolean"
    }
  }
}
