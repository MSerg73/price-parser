{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "DimensionRule",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "profile",
    "max_absolute_delta",
    "status",
    "source_reference"
  ],
  "properties": {
    "id": {
      "type": "string",
      "minLength": 1
    },
    "profile": {
      "type": "string",
      "minLength": 1
    },
    "max_absolute_delta": {
      "type": "array",
      "minItems": 3,
      "maxItems": 3,
      "items": {
        "type": [
          "number",
          "null"
        ],
        "minimum": 0
      }
    },
    "status": {
      "enum": [
        "CONFIRMED",
        "PROPOSED",
        "REJECTED"
      ]
    },
    "source_reference": {
      "type": "string"
    }
  }
}
